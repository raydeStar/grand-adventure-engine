# Grand Adventure Engine - Environment Configuration
# Copy this file to .env and fill in your values.
# All values below are local-development defaults.

# AI Narrator
# Use OpenAICompatible for LM Studio, or Ollama for Ollama's native /api/chat.
LM_STUDIO_PROVIDER=OpenAICompatible
# Endpoint for the narrator API. LM Studio defaults to 1234; Ollama defaults to 11434.
LM_STUDIO_ENDPOINT=http://localhost:1234
# Model name loaded in the narrator backend. Use "default" to auto-detect.
LM_STUDIO_MODEL=default
# Optional bearer token for protected OpenAI-compatible backends such as Unsloth Studio.
LM_STUDIO_API_KEY=
# Optional request options. For Ollama, these become options.num_ctx and think.
LM_STUDIO_CONTEXT_LENGTH=
LM_STUDIO_THINK=

# Discord Bot (optional - leave empty for dashboard-only mode)
DISCORD_TOKEN=
DISCORD_CHANNEL_ID=

# Dashboard Credentials
GAE_DASHBOARD_USER_USERNAME=user
GAE_DASHBOARD_USER_PASSWORD=GAE-User-Local!123
GAE_DASHBOARD_ADMIN_USERNAME=admin
GAE_DASHBOARD_ADMIN_PASSWORD=GAE-Admin-Local!123
# Set to true only for private local demos; false keeps passwords out of anonymous login hints.
GAE_DASHBOARD_SHOW_LOGIN_PASSWORDS=false

# Network Ports
GAE_HOST_PORT=8181
POSTGRES_HOST_PORT=5432

# Database
GAE_DB_PASSWORD=gae_dev_password
